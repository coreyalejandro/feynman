{
  "schema_version": "1.0.0",
  "state_machine": {
    "states": [
      "draft_build",
      "committee_review",
      "product_vote",
      "safety_vote",
      "reconciliation",
      "sign_and_bind",
      "enforced",
      "sunset",
      "struck"
    ],
    "transitions": [
      { "from": "draft_build", "to": "committee_review" },
      { "from": "committee_review", "to": "product_vote" },
      { "from": "committee_review", "to": "safety_vote" },
      { "from": "product_vote", "to": "reconciliation" },
      { "from": "safety_vote", "to": "reconciliation" },
      { "from": "reconciliation", "to": "sign_and_bind" },
      { "from": "sign_and_bind", "to": "enforced" },
      { "from": "enforced", "to": "sunset" }
    ],
    "any_to_struck": true
  },
  "required_artifacts": {
    "baseline": [
      "BUILD_CONTRACT.md",
      "decision.md",
      "verification.md",
      "evidence/"
    ],
    "per_state": {
      "committee_review": ["evidence/index.md"],
      "product_vote": ["decision.md"],
      "safety_vote": ["decision.md"],
      "reconciliation": ["decision.md"],
      "sign_and_bind": ["decision.md", "verification.md"],
      "enforced": ["verification.md"]
    }
  }
}

