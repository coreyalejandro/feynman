{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLC Export Bundle Rules Schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "state_machine", "required_artifacts"],
  "properties": {
    "schema_version": { "type": "string" },
    "state_machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["states", "transitions", "any_to_struck"],
      "properties": {
        "states": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "any_to_struck": { "type": "boolean" }
      }
    },
    "required_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "per_state"],
      "properties": {
        "baseline": {
          "type": "array",
          "items": { "type": "string" }
        },
        "per_state": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}

