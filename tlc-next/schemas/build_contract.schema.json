{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TLC Build Contract (I’m Just a Build) v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "state", "transitions", "scope", "evidence"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^BUILD-[A-Z0-9]{4}-[0-9]{4}$"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Superseded", "Rejected"]
    },
    "state": {
      "type": "string",
      "enum": [
        "draft_build",
        "committee_review",
        "product_vote",
        "safety_vote",
        "reconciliation",
        "sign_and_bind",
        "enforced",
        "struck",
        "sunset"
      ]
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "timestamp_utc", "by", "reason"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "timestamp_utc": { "type": "string" },
          "by": { "type": "string" },
          "reason": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "change_summary"],
      "properties": {
        "project": { "type": "string" },
        "change_summary": { "type": "string" },
        "safety_critical": { "type": "boolean", "default": false }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "present"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "present": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

